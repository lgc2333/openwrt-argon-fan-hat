#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99

start_service() {
	procd_open_instance argon-fan
	procd_set_param command /usr/sbin/argon-fan-daemon
	procd_set_param file /etc/config/argon_fan
	procd_set_param stderr 1
	procd_set_param stdout 1
	procd_set_param respawn
	procd_close_instance
}

stop_service() {
	# Set the fan to 50% when the service stops, like default behavior
	if i2cget -y 1 0x1a 0x80 >/dev/null 2>&1; then
		i2cset -y 1 0x1a 0x80 50 >/dev/null 2>&1
	else
		i2cset -y 1 0x1a 50 >/dev/null 2>&1
	fi
}

service_triggers() {
	procd_add_reload_trigger "argon_fan"
}
